# MongoDB (local: mongodb://127.0.0.1:27017/substitute-list)
MONGODB_URI=mongodb://127.0.0.1:27017/substitute-list

# Admin (se crea en el primer login si no existe la tienda)
ADMIN_EMAIL=admin@tutienda.com
ADMIN_PASSWORD=cambiar-en-produccion

# Firma de sesión (cadena aleatoria de 32+ caracteres)
SESSION_SECRET=reemplazar-con-un-secreto-largo-y-aleatorio

# Nombre visible de la tienda
STORE_NAME=Mi liga local

# Zona horaria para las horas límite (ej. America/Santiago)
STORE_TIMEZONE=America/Santiago

# URL pública de la app (Vercel: https://tu-proyecto.vercel.app)
NEXT_PUBLIC_APP_URL=https://tu-proyecto.vercel.app

# Mercado Pago — Access Token de producción o prueba
# https://www.mercadopago.cl/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=

# true = usar checkout de prueba (sandbox_init_point)
MERCADOPAGO_SANDBOX=false
